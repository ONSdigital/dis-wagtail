{% load wagtailadmin_tags wagtailcore_tags %}
{% comment %}
    FIXME: Remove once using a release which includes the fix for github.com/wagtail/wagtail/issues/13325
{% endcomment %}

{% if page.live %}
    {% pageurl page as page_url %}
    {% if page_url is not None %}
        {% test_page_is_public page as is_public %}
        {% comment %} Two copies of the tag, visibility is toggled by the privacy switch JS {% endcomment %}
        <a
            href="{{ page_url }}"
            target="_blank"
            rel="noreferrer"
            class="{% classnames 'page-status-tag' is_public|yesno:',w-hidden' %}"
            aria-label="Visible to all. Visit the live page"
            data-controller="w-tooltip w-zone"
            data-action="w-privacy:changed@document->w-zone#switch"
            data-w-tooltip-content-value="Visible to all"
            data-w-tooltip-offset-value="[0, 13]"
            data-w-zone-inactive-class="w-hidden"
            data-w-zone-switch-key-value="isPublic"
        >
            {% icon classname='w-w-4 w-h-4 w-mr-1' name="view" %}
            Live
        </a>
        <a
            href="{{ page_url }}"
            target="_blank"
            rel="noreferrer"
            class="{% classnames 'page-status-tag' is_public|yesno:'w-hidden,' %}"
            aria-label="Private. Visit the live page"
            data-controller="w-tooltip w-zone"
            data-action="w-privacy:changed@document->w-zone#switch"
            data-w-tooltip-content-value="Private"
            data-w-tooltip-offset-value="[0, 13]"
            data-w-zone-inactive-class="w-hidden"
            data-w-zone-switch-key-value="!isPublic"
        >
            {% icon classname='w-w-4 w-h-4 w-mr-1' name="no-view" %}
            Private
        </a>
    {% endif %}
{% endif %}
